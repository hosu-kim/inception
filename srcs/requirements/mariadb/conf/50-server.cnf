# -server.cnf 앞에 있는 숫자는 여러 개 있을 경우 우선순위로 읽힌다: 10, 50, 90...
                                        # Set the rules for server operation
[mysqld]                                # commands to the server engine
user = mysql                            # user name
pid-file = /run/mysqld/mysqld.pid       # directory to store MariaDB's PID
socket = /run/mysqld/mysqld.sock        # 
port = 3306
basedir = /usr
datadir = /var/lib/mysql
tmpdir = /tmp
lc-messages-dir = /usr/share/mysql      # directory for error msgs
bind-address = 0.0.0.0                  # Allow access regardless of any IP address
query_cache_size = 16M                  # Request query size
log_error = /var/log/mysql/error.log    # log directory
